# zoom_meeting_manager.cfg
#
# Configuration for zmm (Zoom Meeting Manager).
#
# zmm searches for this file in order:
#   1. --config PATH (explicit)
#   2. ./zoom_meeting_manager.cfg (current directory)
#   3. <zmm install dir>/zoom_meeting_manager.cfg
#   4. ~/.config/zoom_meeting_manager.cfg
#
# If no config file is found, zmm falls back to ~/.config/opencode/opencode.json
# for API credentials and model information.
#
# All fields are optional. Blank values fall through to opencode.json or defaults.
# Generate a starter config interactively with: zmm init config
#
# Docs: zmm show config    (see active configuration)
#       zmm show prompt    (see full model directive)
#       zmm list prompts   (see available prompts)


# ─── Paths ───────────────────────────────────────────────────────────────────
[paths]

# Where Zoom stores raw meeting recordings.
# Each meeting is a folder like: "2026-06-04 15.29.53 Meeting Title/"
# containing meeting_saved_closed_caption.txt and/or meeting_saved_chat.txt
input_dir =

# Where zmm writes all processed output. Creates subdirectories automatically:
#   Merged-Transcripts-YYYY/   — merged caption+chat files
#   Summaries-YYYY/            — LLM-generated summary .txt and .json
#   Cleaned-Transcripts-YYYY/  — LLM-cleaned transcripts
#   Diagnostics/YYYY/          — failed model response dumps
#   to-delete/                 — raw dirs moved by 'zmm delete raw'
output_dir =


# ─── Source ──────────────────────────────────────────────────────────────────
[source]

# Transcript source type. Currently only "zoom" is implemented.
type = zoom


# ─── API ─────────────────────────────────────────────────────────────────────
[api]

# OpenAI-compatible API endpoint.
# Leave blank to use the default OpenAI endpoint (https://api.openai.com/v1).
# Leave this entire section blank if ~/.config/opencode/opencode.json provides
# your API credentials — zmm will use that automatically.
#
# Examples:
#   base_url = https://api.openai.com/v1
#   base_url = https://llmgw.example.com/v1
base_url =

# API key. Supports several formats:
#   Literal:     sk-abc123...
#   Env var:     {env:OPENAI_API_KEY}
#   Shell var:   $OPENAI_API_KEY or ${OPENAI_API_KEY}
#
# If blank, zmm reads from ~/.config/opencode/opencode.json.
api_key =

# Some providers don't support the temperature parameter.
# Set to true to omit it from API calls.
no_temperature = false


# ─── Models ──────────────────────────────────────────────────────────────────
[models]

# Blank = fall back to opencode.json's cheapest model.
# CLI overrides: --summary-model, --cleanup-model
#
# summary: used by zmm summarize, zmm fix missing summaries
#          (needs a capable model — must produce structured JSON)
# cleanup: used by zmm clean transcripts
#          (simpler task — can use a cheaper/faster model)
summary =
cleanup =


# ─── User Identity (for 'zmm extract me') ────────────────────────────────────
[user]

# Which [person.NAME] profile to use for 'zmm extract me' commands.
# This drives the local regex search — it does NOT affect the model prompt.
# For model context about yourself, use ~/.config/zmm/prompts/myself.txt
default_person = me

[person.me]

# Your name and aliases are used by 'zmm extract me' to regex-search
# transcripts for mentions of you. This is a local search, no model involved.
display_name =
aliases =


# ─── Transcripts ─────────────────────────────────────────────────────────────
[transcripts]

# Which transcript version to summarize when both exist:
#   cleaned_if_available — use cleaned transcript if it exists, else merged (default)
#   cleaned              — prefer cleaned, skip if missing
#   required_cleaned     — require cleaned, error if missing
#   merged               — always use the canonical merged transcript
summarization_source = cleaned_if_available

# Whether to automatically run LLM cleanup before summarizing.
# Usually false — run 'zmm clean transcripts' separately first.
auto_clean_before_summarize = false


# ─── Output ──────────────────────────────────────────────────────────────────
[output]

# Write Processing-YYYY.json metadata after state-changing commands.
write_processing_json = true

# Aggregate export period: auto, year, month, range
aggregate_period = auto

# Include summaries from all models in aggregate files.
# Set to false to only include the configured summary model.
include_all_model_summaries = true

# Prompt for confirmation before model-backed bulk operations.
# Set to false to suppress (same as --yes).
confirm_model_calls = true

# Color mode for terminal output: auto, always, never
color = auto
